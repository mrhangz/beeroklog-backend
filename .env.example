# Server
PORT=8080
# Set to "production" on real deployments; enforces a non-default JWT_SECRET.
APP_ENV=development

# CORS
# Comma-separated browser origins allowed to call the API (for the web app).
# Leave empty to send no CORS headers; "*" allows any origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://beeroklog:beeroklog@localhost:5432/beeroklog?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Google OAuth
# Accepts a comma-separated allowlist of Google OAuth client IDs whose ID tokens
# the backend will trust. Include the Android server client ID and any iOS/web
# client IDs that are expected to mint Google ID tokens for BeerOklog.
GOOGLE_CLIENT_IDS=11829879547-7jnv2ct29ivj8gippra6uro50obacr02.apps.googleusercontent.com

# Comma-separated emails that receive is_admin=true on sign-in /me (grant only; no auto-revoke).
# You can also grant manually: UPDATE users SET is_admin = true WHERE email = '...';
ADMIN_EMAILS=

# Apple Sign In
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=your-apple-client-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./apple_auth_key.p8

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=beeroklog-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true
