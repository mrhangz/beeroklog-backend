# BeerOklog backend example environment for a Docker host on Proxmox.
# Copy to `.env` on the server and replace the placeholder values.

# Server
PORT=8080

# Database
# If you keep the included docker-compose service names, `postgres` will resolve inside the compose network.
DATABASE_URL=postgres://beeroklog:CHANGE_ME_DB_PASSWORD@postgres:5432/beeroklog?sslmode=disable

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Google OAuth
# Include every Google OAuth client ID that BeerOklog should trust.
# For your current testing, start with the provided client ID and add more if iOS/Android end up using different audiences.
GOOGLE_CLIENT_IDS=11829879547-7jnv2ct29ivj8gippra6uro50obacr02.apps.googleusercontent.com

# Apple Sign In
# Only required if you want to test Apple sign-in.
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=your-apple-client-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=/run/secrets/apple_auth_key.p8

# S3 / MinIO
# If you keep the included MinIO compose service, these defaults can stay aligned with compose.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=beeroklog-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
S3_USE_PATH_STYLE=true
